<%- include('partials/header', { title: 'Create Booking' }) %>

    <header class="form-page-header">
      <h1>📅 Create New Booking</h1>
    </header>

    <main class="app-main">
      <div class="form-container">
        <div class="form-card">
          <form id="booking-form">
            <div class="form-group">
              <label for="customerName">Customer Name <span class="required">*</span></label>
              <input id="customerName" name="customerName" class="form-control" placeholder="e.g. John Doe" required />
            </div>

            <div class="form-group">
              <label for="carNumber">Select Car <span class="required">*</span></label>
              <select id="carNumber" name="carNumber" class="form-control" required>
                <option value="">-- Select a car --</option>
                <% cars.forEach(function(car) { %>
                  <option value="<%= car.carNumber %>" data-price="<%= car.pricePerDay %>">
                    <%= car.carNumber %> — $<%= Number(car.pricePerDay).toFixed(2) %>/day
                    <% if (car.capacity) { %>(<%= car.capacity %> seats)<% } %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="form-group">
              <label for="startDate">Start Date <span class="required">*</span></label>
              <input id="startDate" name="startDate" type="date" class="form-control" required />
            </div>

            <div class="form-group">
              <label for="endDate">End Date <span class="required">*</span></label>
              <input id="endDate" name="endDate" type="date" class="form-control" required />
            </div>

            <!-- Live Price Preview -->
            <div class="price-preview" id="price-preview">
              <div class="price-row">
                <span>Price per day</span>
                <span class="price-value" id="ppd-display">$0.00</span>
              </div>
              <div class="price-row">
                <span>Rental days</span>
                <span class="price-value" id="days-display">0</span>
              </div>
              <div class="price-row total">
                <span>Total Amount</span>
                <span class="price-value" id="total-display">$0.00</span>
              </div>
            </div>

            <div class="form-actions">
              <button class="btn btn-primary btn-lg" type="submit" id="submit-btn">
                📅 Create Booking
              </button>
              <a class="btn btn-secondary" href="/">Cancel</a>
            </div>
            <div class="form-status" id="status"></div>
          </form>
        </div>
      </div>
    </main>

    <script>
      (function() {
        var form = document.getElementById("booking-form");
        var status = document.getElementById("status");
        var submitBtn = document.getElementById("submit-btn");
        var pricePreview = document.getElementById("price-preview");
        var ppdDisplay = document.getElementById("ppd-display");
        var daysDisplay = document.getElementById("days-display");
        var totalDisplay = document.getElementById("total-display");

        var carSelect = document.getElementById("carNumber");
        var startInput = document.getElementById("startDate");
        var endInput = document.getElementById("endDate");

        // Set min date to today
        var today = new Date().toISOString().slice(0, 10);
        startInput.setAttribute("min", today);
        endInput.setAttribute("min", today);

        // Live price calculation
        function updatePricePreview() {
          var selected = carSelect.options[carSelect.selectedIndex];
          var pricePerDay = selected && selected.dataset.price ? parseFloat(selected.dataset.price) : 0;
          var startVal = startInput.value;
          var endVal = endInput.value;

          if (pricePerDay > 0 && startVal && endVal) {
            var start = new Date(startVal);
            var end = new Date(endVal);
            if (end > start) {
              var diff = Math.max(1, Math.round((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24)));
              var total = diff * pricePerDay;
              ppdDisplay.textContent = "$" + pricePerDay.toFixed(2);
              daysDisplay.textContent = diff + " day" + (diff > 1 ? "s" : "");
              totalDisplay.textContent = "$" + total.toFixed(2);
              pricePreview.classList.add("visible");
              return;
            }
          }
          pricePreview.classList.remove("visible");
        }

        carSelect.addEventListener("change", updatePricePreview);
        startInput.addEventListener("change", updatePricePreview);
        endInput.addEventListener("change", updatePricePreview);

        // Form submission
        form.addEventListener("submit", async function(event) {
          event.preventDefault();

          var payload = {
            customerName: form.customerName.value.trim(),
            carNumber: form.carNumber.value,
            startDate: form.startDate.value,
            endDate: form.endDate.value,
          };

          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span class="spinner"></span> Creating...';
          status.className = "form-status";
          status.style.display = "none";

          var response = await fetch("/bookings", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          var result = await response.json().catch(function() { return {}; });

          if (!response.ok) {
            status.textContent = result.message || "Failed to create booking";
            status.className = "form-status visible error";
            submitBtn.disabled = false;
            submitBtn.innerHTML = "📅 Create Booking";
            return;
          }

          status.textContent = "✅ Booking created successfully! Redirecting...";
          status.className = "form-status visible success";
          setTimeout(function() { window.location.href = "/"; }, 800);
        });
      })();
    </script>

<%- include('partials/footer') %>