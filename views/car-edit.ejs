<%- include('partials/header', { title: 'Edit Car - ' + car.carNumber }) %>

    <header class="form-page-header">
      <h1>✏️ Edit Car — <%= car.carNumber %></h1>
    </header>

    <main class="app-main">
      <div class="form-container">
        <div class="form-card">
          <form id="car-edit-form">
            <div class="form-group">
              <label for="carNumber">Car Number <span class="required">*</span></label>
              <input id="carNumber" name="carNumber" class="form-control" value="<%= car.carNumber %>" required />
            </div>

            <div class="form-group">
              <label for="capacity">Capacity (seats) <span class="required">*</span></label>
              <input id="capacity" name="capacity" type="number" min="1" class="form-control" value="<%= car.capacity %>" required />
            </div>

            <div class="form-group">
              <label for="status">Status</label>
              <select id="status" name="status" class="form-control">
                <option value="available" <%= car.status === 'available' ? 'selected' : '' %>>✅ Available</option>
                <option value="rented" <%= car.status === 'rented' ? 'selected' : '' %>>🔴 Rented</option>
                <option value="maintenance" <%= car.status === 'maintenance' ? 'selected' : '' %>>🔧 Maintenance</option>
              </select>
            </div>

            <div class="form-group">
              <label for="pricePerDay">Price Per Day ($) <span class="required">*</span></label>
              <input id="pricePerDay" name="pricePerDay" type="number" min="0" step="0.01" class="form-control" value="<%= car.pricePerDay %>" required />
            </div>

            <div class="form-group">
              <label for="features">Features</label>
              <textarea id="features" name="features" class="form-control" placeholder='e.g. GPS, Air-conditioner, Bluetooth'><%= car.features && car.features.length ? car.features.join(', ') : '' %></textarea>
              <div class="form-hint">Separate features with commas. Leave blank for no features.</div>
            </div>

            <div class="form-group">
              <label for="image">Car Image</label>
              <% if (car.image) { %>
                <div style="margin-bottom: 8px;">
                  <img src="<%= car.image %>" style="max-width: 200px; max-height: 150px; border-radius: 8px; border: 1px solid #e5e7eb;" />
                  <p style="font-size: 12px; color: #6b7280; margin-top: 4px;">Current image. Upload a new one to replace.</p>
                </div>
              <% } %>
              <input id="image" name="image" type="file" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp" />
              <div class="form-hint">Accepted formats: JPEG, PNG, GIF, WebP. Max size: 5MB.</div>
              <div id="image-preview" style="margin-top: 10px; display: none;"></div>
            </div>

            <div class="form-actions">
              <button class="btn btn-primary btn-lg" type="submit" id="submit-btn">
                💾 Save Changes
              </button>
              <a class="btn btn-secondary" href="/">Cancel</a>
            </div>
            <div class="form-status" id="status"></div>
          </form>
        </div>
      </div>
    </main>

    <script>
      (function() {
        var form = document.getElementById("car-edit-form");
        var status = document.getElementById("status");
        var submitBtn = document.getElementById("submit-btn");
        var imageInput = document.getElementById("image");
        var preview = document.getElementById("image-preview");

        // Image preview on file select
        imageInput.addEventListener("change", function() {
          var file = imageInput.files[0];
          if (file) {
            var reader = new FileReader();
            reader.onload = function(e) {
              preview.innerHTML = '<img src="' + e.target.result + '" style="max-width: 200px; max-height: 150px; border-radius: 8px; border: 1px solid #e5e7eb;" />';
              preview.style.display = "block";
            };
            reader.readAsDataURL(file);
          } else {
            preview.style.display = "none";
            preview.innerHTML = "";
          }
        });

        form.addEventListener("submit", async function(event) {
          event.preventDefault();

          var formData = new FormData();
          formData.append("carNumber", form.carNumber.value.trim());
          formData.append("capacity", form.capacity.value);
          formData.append("status", form.status.value);
          formData.append("pricePerDay", form.pricePerDay.value);

          var featuresRaw = form.features.value.trim();
          var features = featuresRaw ? featuresRaw.split(",").map(function(f) { return f.trim(); }).filter(Boolean) : [];
          features.forEach(function(f, i) { formData.append("features[" + i + "]", f); });

          if (imageInput.files[0]) {
            formData.append("image", imageInput.files[0]);
          }

          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span class="spinner"></span> Saving...';
          status.className = "form-status";
          status.style.display = "none";

          var carNumber = encodeURIComponent('<%= car.carNumber %>');
          var response = await fetch("/cars/" + carNumber, {
            method: "PUT",
            body: formData,
          });

          var result = await response.json().catch(function() { return {}; });

          if (!response.ok) {
            status.textContent = result.message || "Failed to update car";
            status.className = "form-status visible error";
            submitBtn.disabled = false;
            submitBtn.innerHTML = "💾 Save Changes";
            return;
          }

          status.textContent = "✅ Car updated successfully! Redirecting...";
          status.className = "form-status visible success";
          setTimeout(function() { window.location.href = "/"; }, 800);
        });
      })();
    </script>

<%- include('partials/footer') %>