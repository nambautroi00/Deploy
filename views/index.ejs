<%- include('partials/header', { title: 'Dashboard' }) %>

    <header class="app-header">
      <div class="header-content">
        <div class="header-left">
          <div class="logo-icon">🚗</div>
          <div>
            <h1>Car Rental Management</h1>
            <div class="header-subtitle">Manage your fleet, bookings, and rental payments.</div>
          </div>
        </div>
        <div class="header-actions">
          <% if (typeof user !== 'undefined' && user) { %>
            <div class="user-menu">
              <% if (user.avatar) { %>
                <img class="user-avatar" src="<%= user.avatar %>" alt="<%= user.displayName %>" />
              <% } else { %>
                <div style="width:36px;height:36px;border-radius:50%;background:#3b82f6;display:flex;align-items:center;justify-content:center;font-size:16px;color:white;"><%= user.displayName.charAt(0) %></div>
              <% } %>
              <span class="user-name"><%= user.displayName %></span>
              <a class="logout-btn" href="/auth/logout">Logout</a>
            </div>
          <% } %>
          <a class="btn btn-primary" href="/cars/new">➕ Add Car</a>
          <a class="btn btn-success" href="/bookings/new">📅 Create Booking</a>
        </div>
      </div>
    </header>

    <main class="app-main">
      <!-- Cars Section -->
      <div class="card">
        <div class="card-header">
          <div class="section-title">
            <span class="title-icon car-icon">🚘</span>
            <span>Car Fleet</span>
            <span class="badge badge-available"><%= cars.length %> cars</span>
          </div>
          <a class="btn btn-primary btn-sm" href="/cars/new">➕ Add Car</a>
        </div>

        <% if (cars.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">🚗</div>
            <p>No cars available. Click "Add Car" to get started.</p>
          </div>
        <% } else { %>
          <div class="table-wrapper">
              <table>
                <thead>
                  <tr>
                    <th>Image</th>
                    <th>Car Number</th>
                    <th>Capacity</th>
                    <th>Status</th>
                    <th>Price / Day</th>
                    <th>Features</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% cars.forEach(function(car) { %>
                    <tr>
                      <td>
                        <% if (car.image) { %>
                          <img src="<%= car.image %>" alt="<%= car.carNumber %>" style="width: 60px; height: 45px; object-fit: cover; border-radius: 6px; border: 1px solid var(--gray-200);" />
                        <% } else { %>
                          <span style="font-size: 24px; opacity: 0.3;">🚗</span>
                        <% } %>
                      </td>
                      <td><span class="car-number"><%= car.carNumber %></span></td>
                      <td><span class="car-capacity">👤 <%= car.capacity %> seats</span></td>
                      <td>
                        <span class="badge badge-<%= car.status %>"><%= car.status.charAt(0).toUpperCase() + car.status.slice(1) %></span>
                      </td>
                      <td><span class="price-display"><%= Number(car.pricePerDay).toFixed(2) %> / day</span></td>
                      <td>
                        <% if (car.features && car.features.length) { %>
                          <span style="font-size: 13px; color: var(--gray-600);"><%= car.features.join(', ') %></span>
                        <% } else { %>
                          <span style="color: var(--gray-400); font-style: italic;">—</span>
                        <% } %>
                      </td>
                      <td>
                        <div class="actions">
                          <a class="btn btn-warning btn-sm" href="/cars/<%= car.carNumber %>/edit">✏️ Edit</a>
                          <button class="btn btn-danger btn-sm" onclick="deleteCar('<%= car.carNumber %>')">🗑️ Delete</button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
          </div>
        <% } %>
      </div>

      <!-- Bookings Section -->
      <div class="card">
        <div class="card-header">
          <div class="section-title">
            <span class="title-icon booking-icon">📋</span>
            <span>Booking Records</span>
            <span class="badge badge-rented"><%= bookings.length %> bookings</span>
          </div>
          <a class="btn btn-success btn-sm" href="/bookings/new">📅 Create Booking</a>
        </div>

        <% if (bookings.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">📭</div>
            <p>No bookings yet. Click "Create Booking" to start.</p>
          </div>
        <% } else { %>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Customer</th>
                  <th>Car</th>
                  <th>Start Date</th>
                  <th>End Date</th>
                  <th>Rental Days</th>
                  <th>Total Amount</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% bookings.forEach(function(booking) { %>
                  <% 
                    var start = new Date(booking.startDate);
                    var end = new Date(booking.endDate);
                    var days = Math.max(1, Math.round((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24)));
                  %>
                  <tr>
                    <td><strong><%= booking.customerName %></strong></td>
                    <td><%= booking.carNumber %></td>
                    <td><%= start.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                    <td><%= end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                    <td><%= days %> day<%= days > 1 ? 's' : '' %></td>
                    <td><span class="price-display"><%= Number(booking.totalAmount).toFixed(2) %></span></td>
                    <td>
                      <div class="actions">
                        <a class="btn btn-warning btn-sm" href="/bookings/<%= booking._id %>/edit">✏️ Edit</a>
                        <button class="btn btn-danger btn-sm" onclick="deleteBooking('<%= booking._id %>')">🗑️ Delete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </main>

    <footer class="app-footer">
      <p>Car Rental Management System &copy; 2026 &mdash; Built with Node.js & MongoDB</p>
    </footer>

<%- include('partials/footer') %>